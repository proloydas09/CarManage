# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://antigravity:antigravity_dev@localhost:5433/antigravity?schema=public"

# --- Cache (Redis) ---
REDIS_URL="redis://localhost:6379"

# --- Authentication ---
JWT_SECRET="generate-a-long-random-string-for-production"
REFRESH_TOKEN_SECRET="generate-another-long-random-string"

# --- API Configuration ---
PORT=4000
HOST="0.0.0.0"
CORS_ORIGIN="http://localhost:3000,https://your-domain.com"

# --- External Services (Optional) ---
# RESEND_API_KEY="" # For emails
# TWILIO_ACCOUNT_SID="" # For SMS
# TWILIO_AUTH_TOKEN=""
# TWILIO_PHONE_NUMBER=""

# --- Frontend (Web) ---
# NEXT_PUBLIC_API_URL should point to your API domain
NEXT_PUBLIC_API_URL="http://localhost:4000"

# --- Node Environment ---
NODE_ENV="development" # Change to "production" in live environment
