{
  "name": "antigravity",
  "private": true,
  "version": "1.0.0",
  "description": "Antigravity — Fleet & P&L Management SaaS for Indian Travel Operators",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "db:migrate": "pnpm --filter @antigravity/api prisma migrate dev",
    "db:seed": "pnpm --filter @antigravity/api prisma db seed",
    "db:studio": "pnpm --filter @antigravity/api prisma studio",
    "db:reset": "pnpm --filter @antigravity/api prisma migrate reset"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4"
}
